generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PrinterStatus {
  LISTA
  IMPRIMIENDO
  MANTENIMIENTO
}

model Printer {
  id             String        @id @default(uuid())
  name           String
  normalizedName String
  status         PrinterStatus @default(LISTA)
  model          String?
  location       String?
  ipWifi         String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([active])
  @@index([normalizedName])
  @@index([status])
}
